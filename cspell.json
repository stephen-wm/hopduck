{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    ".git",
    ".next",
    "node_modules",
    "public",
    "*.lock",
    "package-lock.json",
    "*.min.js",
    "*.map",
    "tsconfig.tsbuildinfo",
    ".vscode",
    ".env*"
  ],
  "dictionaryDefinitions": [
    {
      "name": "project-terms",
      "path": "./.cspell/project-terms.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "git",
    "filetypes",
    "npm",
    "typescript",
    "json",
    "css",
    "html",
    "markdown",
    "node",
    "lorem-ipsum",
    "softwareTerms",
    "misc",
    "project-terms"
  ],
  "words": [
    "hopduck",
    "ultracite",
    "oxlint",
    "oxfmt",
    "oxc",
    "geist",
    "nextjs",
    "vercel",
    "commitlint",
    "lintstagedrc",
    "husky",
    "tailwindcss",
    "vscode",
    "mkdir",
    "unlink",
    "tsgolint",
    "feat",
    "fix",
    "docs",
    "chore",
    "refactor",
    "perf",
    "build",
    "ci",
    "revert",
    "deps"
  ],
  "ignoreWords": [],
  "patterns": [
    {
      "name": "hexColor",
      "pattern": "(?:#)?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6}"
    }
  ],
  "ignoreRegExpList": [
    "/\\b[a-z]+rc\\b/",
    "/^(feat|fix|docs|chore|refactor|test|build|ci|perf)(\\(.+\\))?:/"
  ],
  "import": []
}
